{
  "$schema": "./node_modules/@i18next-toolkit/cli/config-schema.json",
  "publicDir": "./public",
  "defaultLocale": "en",
  "locales": [
    "en",
    "zh",
    "ja",
    "ko",
    "es",
    "pt",
    "fr",
    "de",
    "id",
    "vi",
    "ru",
    "it"
  ],
  "namespaces": [
    "translation"
  ],
  "verbose": true,
  "extractor": {
    "input": [
      "./src/**/*.{ts,tsx}",
      "!./src/**/*.spec.{ts,tsx}",
      "!**/node_modules/**"
    ],
    "output": "./public/locales"
  },
  "scanner": {
    "source": "./src/**/*.tsx",
    "tsconfigPath": "./tsconfig.json",
    "autoImport": false,
    "ignoreFiles": [],
    "ignoreText": []
  },
  "translator": {
    "type": "openai",
    "openai": {
      "modelName": "gpt-4o-mini"
    }
  }
}